<file path="games/snake/index.html">
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Arcade Snake Standalone</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.0/p5.min.js"></script>
  <style>
    body {
      margin: 0;
      padding: 0;
      background: #0b110e;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      font-family: monospace;
      color: #fff;
      overflow: hidden;
    }
    #canvas-container {
      border: 4px solid #22c55e;
      box-shadow: 0 0 25px rgba(34, 197, 94, 0.4);
      border-radius: 8px;
    }
  </style>
</head>
<body>
  <div id="canvas-container"></div>

  <script>
    // ponytail: simple native audio synth
    let audioCtx = null;
    function playTone(freq, type, duration) {
      try {
        if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        if (audioCtx.state === 'suspended') audioCtx.resume();
        let osc = audioCtx.createOscillator();
        let gain = audioCtx.createGain();
        osc.type = type || 'sine';
        osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
        gain.gain.setValueAtTime(0.08, audioCtx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + duration);
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        osc.start();
        osc.stop(audioCtx.currentTime + duration);
      } catch (e) {}
    }

    let state = 'MENU'; // MENU, PLAY, GAMEOVER
    let score = 0, highScore = 0;
    
    const cols = 40, rows = 25, cellSize = 20;
    const w = cols * cellSize, h = rows * cellSize;

    let snake = [];
    let dir = { x: 1, y: 0 };
    let nextDir = { x: 1, y: 0 };
    let food = { x: 0, y: 0, isGold: false };
    let frameDelay = 7;
    let powerTimer = 0;
    let particles = [];

    function setup() {
      let canvas = createCanvas(w, h);
      canvas.parent('canvas-container');
      frameRate(60);
      loadHighScore();
    }

    function draw() {
      background(10, 15, 12);
      drawGridLines();

      if (state === 'MENU') {
        drawMenu();
      } else if (state === 'PLAY') {
        updateGame();
        drawGame();
      } else if (state === 'GAMEOVER') {
        drawGameOver();
      }

      updateAndDrawParticles();
    }

    function drawGridLines() {
      stroke(34, 197, 94, 10);
      strokeWeight(1);
      for (let x = 0; x < w; x += cellSize) {
        line(x, 0, x, h);
      }
      for (let y = 0; y < h; y += cellSize) {
        line(0, y, w, y);
      }
    }

    function drawMenu() {
      textAlign(CENTER, CENTER);
      fill(34, 197, 94);
      textSize(36);
      textStyle(BOLD);
      text("NEON SNAKE", w / 2, 130);

      fill(200);
      textSize(18);
      textStyle(NORMAL);
      text(`Record Actual: ${highScore} pts`, w / 2, 210);
      
      fill(34, 197, 94);
      textSize(20);
      text("Presiona ENTER o ESPACIO para Jugar", w / 2, 280);

      fill(120);
      textSize(14);
      text("Controles: Flechas de dirección o WASD", w / 2, 380);
    }

    function drawGame() {
      // Draw Food
      if (food.isGold) {
        fill(234, 179, 8);
        ellipse(food.x * cellSize + cellSize/2, food.y * cellSize + cellSize/2, cellSize * 0.95);
      } else {
        fill(239, 68, 68);
        ellipse(food.x * cellSize + cellSize/2, food.y * cellSize + cellSize/2, cellSize * 0.8);
      }

      // Draw Snake
      for (let i = 0; i < snake.length; i++) {
        if (i === 0) {
          fill(34, 197, 94);
        } else {
          fill(22, 163, 74, map(i, 0, snake.length, 255, 100));
        }
        rect(snake[i].x * cellSize + 1, snake[i].y * cellSize + 1, cellSize - 2, cellSize - 2, 4);
      }

      // Draw HUD
      fill(255, 255, 255, 180);
      textSize(16);
      textAlign(LEFT, TOP);
      text(`Puntos: ${score}`, 20, 20);
      if (powerTimer > 0) {
        fill(234, 179, 8);
        text(`¡SUPER VELOCIDAD! (${Math.ceil(powerTimer / 60)}s)`, 150, 20);
      }
    }

    function drawGameOver() {
      textAlign(CENTER, CENTER);
      fill(239, 68, 68);
      textSize(36);
      text("GAME OVER", w / 2, 160);

      fill(200);
      textSize(20);
      text(`Tu puntuación final: ${score} pts`, w / 2, 220);
      fill(34, 197, 94);
      text("Presiona ENTER para continuar", w / 2, 300);
    }

    function updateGame() {
      if (powerTimer > 0) {
        powerTimer--;
      }

      // ponytail: throttle movement speed frame rate
      let currentDelay = powerTimer > 0 ? 3 : frameDelay;
      if (frameCount % currentDelay !== 0) return;

      dir = nextDir;
      let head = snake[0];
      let newHead = { x: head.x + dir.x, y: head.y + dir.y };

      // Border wrap-around
      if (newHead.x < 0) newHead.x = cols - 1;
      if (newHead.x >= cols) newHead.x = 0;
      if (newHead.y < 0) newHead.y = rows - 1;
      if (newHead.y >= rows) newHead.y = 0;

      // Self-collision check
      for (let part of snake) {
        if (newHead.x === part.x && newHead.y === part.y) {
          endGame();
          return;
        }
      }

      snake.unshift(newHead);

      // Eat food?
      if (newHead.x === food.x && newHead.y === food.y) {
        eatFood();
      } else {
        snake.pop();
      }
    }

    function eatFood() {
      let points = food.isGold ? 5 : 1;
      score += points;

      if (food.isGold) {
        powerTimer = 300; // 5 seconds of speed boost
        playTone(600, 'sine', 0.25);
        createExplosion(food.x * cellSize + cellSize/2, food.y * cellSize + cellSize/2, '#eab308');
      } else {
        playTone(450, 'triangle', 0.1);
        createExplosion(food.x * cellSize + cellSize/2, food.y * cellSize + cellSize/2, '#22c55e');
      }

      spawnFood();
    }

    function spawnFood() {
      let valid = false;
      while (!valid) {
        food.x = floor(random(cols));
        food.y = floor(random(rows));
        valid = true;
        for (let part of snake) {
          if (part.x === food.x && part.y === food.y) {
            valid = false;
            break;
          }
        }
      }
      food.isGold = random() < 0.15; // 15% chance of gold apple
    }

    function initGame() {
      snake = [
        { x: 10, y: 12 },
        { x: 9, y: 12 },
        { x: 8, y: 12 }
      ];
      dir = { x: 1, y: 0 };
      nextDir = { x: 1, y: 0 };
      score = 0;
      powerTimer = 0;
      spawnFood();
      state = 'PLAY';
    }

    function endGame() {
      state = 'GAMEOVER';
      playTone(150, 'sawtooth', 0.5);
      if (score > highScore) {
        highScore = score;
        saveHighScore();
      }
    }

    function loadHighScore() {
      try {
        let val = localStorage.getItem('arcade_snake_hs');
        if (val) highScore = parseInt(val);
      } catch (e) {}
    }

    function saveHighScore() {
      try {
        localStorage.setItem('arcade_snake_hs', highScore);
      } catch (e) {}
    }

    function keyPressed() {
      if (state === 'MENU') {
        if (keyCode === ENTER || key === ' ') {
          initGame();
        }
      } else if (state === 'GAMEOVER') {
        if (keyCode === ENTER || key === ' ') {
          state = 'MENU';
        }
      } else if (state === 'PLAY') {
        if ((keyCode === UP_ARROW || key === 'w' || key === 'W') && dir.y === 0) {
          nextDir = { x: 0, y: -1 };
        } else if ((keyCode === DOWN_ARROW || key === 's' || key === 'S') && dir.y === 0) {
          nextDir = { x: 0, y: 1 };
        } else if ((keyCode === LEFT_ARROW || key === 'a' || key === 'A') && dir.x === 0) {
          nextDir = { x: -1, y: 0 };
        } else if ((keyCode === RIGHT_ARROW || key === 'd' || key === 'D') && dir.x === 0) {
          nextDir = { x: 1, y: 0 };
        }
      }
    }

    // ponytail: simple particle explosion
    function createExplosion(x, y, color) {
      for (let i = 0; i < 12; i++) {
        particles.push({
          x: x, y: y,
          vx: random(-4, 4), vy: random(-4, 4),
          life: 255, color: color
        });
      }
    }

    function updateAndDrawParticles() {
      for (let i = particles.length - 1; i >= 0; i--) {
        let p = particles[i];
        p.x += p.vx;
        p.y += p.vy;
        p.life -= 15;
        if (p.life <= 0) {
          particles.splice(i, 1);
        } else {
          noStroke();
          let c = color(p.color);
          fill(red(c), green(c), blue(c), p.life);
          ellipse(p.x, p.y, 6);
        }
      }
    }
  </script>
</body>
</html>
